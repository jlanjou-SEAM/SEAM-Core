    "raw": "primary_raw endpoints: live unresolved observations",
    "decoded": "secondary_curated endpoints by default: interpreted/unofficial evidence",
    "curated": "explicit epistemic_layer=curated only: official retrospective validation",
    "combined_inputs": [
      "raw",
      "decoded"
    ],
    "curated_role": "comparison/validation only, not predictive synthesis input"
  }
