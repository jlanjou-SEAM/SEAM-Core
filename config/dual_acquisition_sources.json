{
  "pipeline": "cleanroom_dual_path_acquisition",
  "poll_seconds_default": 30,
  "raw_policy": {
    "path": "raw/{source}/{YYYY-MM-DD}/{HHMMSS}_{stream}.payload",
    "allowed_metadata": [
      "timestamp_utc",
      "source",
      "stream",
      "url",
      "bytes",
      "content_type"
    ],
    "rule": "Raw path preserves payload without semantic interpretation."
  },
  "curated_policy": {
    "path": "curated/{source}/{YYYY-MM-DD}/{HHMMSS}_{stream}_curated.json",
    "rule": "Curated path is secondary, used only after primary raw analysis."
  },
