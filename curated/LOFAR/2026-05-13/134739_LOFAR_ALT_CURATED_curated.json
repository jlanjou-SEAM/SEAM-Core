}

.cc_div .b-tg .c-tg:after {
    content: "";
    position: absolute;
    left: .22em;
    top: .2em;
    width: 1.2em;
    height: 1.2em;
    border: none;
    box-sizing: content-box;
    background: #fff;
    background: var(--cc-toggle-knob-bg);
    box-shadow: 0 1px 2px rgb(24 32 35 / 36%);
