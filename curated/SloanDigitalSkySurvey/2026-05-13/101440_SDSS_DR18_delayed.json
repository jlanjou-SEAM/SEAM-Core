                                <div class="caption">
                                    <p>CasJobs</p>
                                </div>
                            </a>
                        </div>
                        <div class="col text-center">
                            <a href="http://compute.sciserver.org/dashboard/" target="_blank">
                                <img src="/dr18/images/sciserver_compute.png" class="sciserver-thumbnail" alt="Sciserver Compute icon" />
                                <div class="caption">
                                    <p>Compute</p>
                                </div>
                            </a>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col text-center">
                            <a href="http://scidrive.org/scidrive/" target="_blank">
                                <img src="/dr18/images/sciserver_icons_SciDrive.png" class="sciserver-thumbnail" alt="SciDrive icon" />
                                <div class="caption">
                                    <p>SciDrive</p>
                                </div>
                            </a>
                        </div>
                        <!--
                            <div class="col text-center">
